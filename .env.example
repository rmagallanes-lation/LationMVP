# ===== LOCAL DEVELOPMENT =====
# Supabase publishable values for any client-side reads only
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Turnstile widget key for contact form challenge
VITE_TURNSTILE_SITE_KEY=0x4AAAAAACoiLYW7NDk0Epfz

# Supabase service-role credentials used server-side by /api/lead
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Turnstile secret for server-side token verification
CF_TURNSTILE_SECRET=0x4AAAAAAAxxxxxxxxxxxxxx-secret

# Upstash Redis credentials for distributed rate limiting
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Allowed browser origins for API requests (exact match, comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://lation.com.mx,https://www.lation.com.mx

# Optional: show technical contact-config hints in the UI outside local dev
# VITE_SHOW_CONTACT_CONFIG_HINT=true
#
# Resend email notification config (used after a successful lead insert)
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM_EMAIL=Lation Leads <leads@lation.com.mx>
# RESEND_NOTIFICATION_TO=ops@lation.com.mx,founder@lation.com.mx

# ===== PRODUCTION (lation.com.mx) =====
# For production, use these values after deployment:
# VITE_API_URL=https://api.lation.com.mx (or your backend domain)
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAACoiLYW7NDk0Epfz
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# CF_TURNSTILE_SECRET=your-cf-turnstile-secret-here
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# ALLOWED_ORIGINS=https://lation.com.mx,https://www.lation.com.mx

# Note: rotate sensitive keys every 90 days (SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY,
# CF_TURNSTILE_SECRET, UPSTASH_REDIS_REST_TOKEN).

# ===== DEMO BRANCH (Vercel Preview: mvp-git-demo-*) =====
# Set all of the following in Vercel → Project Settings → Environment Variables,
# scoped to "Preview" (branch: DEMO).
#
# When VITE_DEMO_MODE=true, /api/lead inserts into leads_demo instead of leads
# and Resend email subjects are prefixed with [DEMO].
# VITE_DEMO_MODE=true
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAACoiLYW7NDk0Epfz
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# CF_TURNSTILE_SECRET=0x4AAAAAAAxxxxxxxxxxxxxx-secret
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM_EMAIL=Lation Leads <leads@lation.com.mx>
# RESEND_NOTIFICATION_TO=ops@lation.com.mx,founder@lation.com.mx
# ALLOWED_ORIGINS=https://mvp-git-demo-rmagallanes-lations-projects.vercel.app

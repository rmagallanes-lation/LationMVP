# ===== LOCAL DEVELOPMENT =====
# Frontend should use this URL to reach the backend API (used by Vite)
VITE_API_URL=http://localhost:3001

# Supabase publishable values for any client-side reads only
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Turnstile widget key for contact form challenge
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx

# Supabase service-role credentials used server-side by /api/lead
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Turnstile secret for server-side token verification
CF_TURNSTILE_SECRET=0x4AAAAAAAxxxxxxxxxxxxxx-secret

# Upstash Redis credentials for distributed rate limiting
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Allowed browser origins for API requests (exact match, comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://lation.com.mx,https://www.lation.com.mx

# Optional: show technical contact-config hints in the UI outside local dev
# VITE_SHOW_CONTACT_CONFIG_HINT=true
#
# Resend email notification config (used after a successful lead insert)
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM_EMAIL=Lation Leads <leads@lation.com.mx>
# RESEND_NOTIFICATION_TO=ops@lation.com.mx,founder@lation.com.mx

# Backend: URL for n8n webhook. If n8n is running on the same Docker host, use host.docker.internal inside containers:
N8N_WEBHOOK_URL=http://localhost:5678
# Optional: shared secret header to protect the n8n webhook
N8N_WEBHOOK_SECRET=

# Legacy CORS variable used by the Express server (comma-separated)
# Prefer ALLOWED_ORIGINS for all API runtimes.
FRONTEND_URL=http://localhost:5173

# Backend port
PORT=3001

# ===== PRODUCTION (lation.com.mx) =====
# For production, use these values after deployment:
# VITE_API_URL=https://api.lation.com.mx (or your backend domain)
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# CF_TURNSTILE_SECRET=0x4AAAAAAAxxxxxxxxxxxxxx-secret
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# ALLOWED_ORIGINS=https://lation.com.mx,https://www.lation.com.mx
# N8N_WEBHOOK_URL=https://n8n.lation.com.mx/webhook/contact (or your n8n tunnel domain + webhook path)
# FRONTEND_URL=https://lation.com.mx,https://www.lation.com.mx (for backend CORS)
# N8N_WEBHOOK_SECRET=change-me
# PORT=3001

# Note: rotate sensitive keys every 90 days (SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY,
# CF_TURNSTILE_SECRET, UPSTASH_REDIS_REST_TOKEN, N8N_WEBHOOK_SECRET).
# If Cloudflare is proxied (orange cloud), add a WAF skip rule for /webhook* to avoid JS challenges.
